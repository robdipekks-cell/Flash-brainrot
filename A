-- ════════════════════════════════════════════
-- //  Auto Collect Loop
-- ════════════════════════════════════════════
task.spawn(function()
    while true do
        if autoCollectEnabled then
            local base = getPlayerBase()
            if base then
                local modelStands = base:FindFirstChild("ModelStands")
                if modelStands then
                    for i = 1, 30 do
                        if not autoCollectEnabled then break end
                        local stand = modelStands:FindFirstChild("ModelStand" .. i)
                        local hitbox = stand
                            and stand:FindFirstChild("StandClaim")
                            and stand.StandClaim:FindFirstChild("StandClaimHitbox")
                        if hitbox then
                            teleportToPart(hitbox)
                            task.wait(0.1)
                        end
                    end
                end
            end
        end
        task.wait(0.5)
    end
end)

-- ════════════════════════════════════════════
-- //  Auto Upgrade Loop
-- ════════════════════════════════════════════
task.spawn(function()
    while true do
        if autoUpgradeEnabled then
            local base = getPlayerBase()
            if base then
                local modelStands = base:FindFirstChild("ModelStands")
                if modelStands then
                    for i = 1, 30 do
                        if not autoUpgradeEnabled then break end
                        local stand = modelStands:FindFirstChild("ModelStand" .. i)
                        if stand then
                            ReplicatedStorage
                                :WaitForChild("Remotes")
                                :WaitForChild("UpgradeBrainrotRemote")
                                :FireServer(base, stand)
                            task.wait(0.1)
                        end
                    end
                end
            end
        end
        task.wait(0.5)
    end
end)

-- ════════════════════════════════════════════
-- //  Auto Treadmill (2x) Loop
-- ════════════════════════════════════════════
task.spawn(function()
    local TrainTreadmillEvent = ReplicatedStorage
        :WaitForChild("Events")
        :WaitForChild("TrainTreadmillEvent")

    while true do
        if autoTreadmillEnabled then
            -- Auto-equip Treadmill from Backpack if not already held
            local character = lp.Character
            local humanoid  = character and character:FindFirstChild("Humanoid")
            local tool      = lp.Backpack:FindFirstChild("Treadmill")
                           or (character and character:FindFirstChild("Treadmill"))

            if humanoid and tool and tool.Parent ~= character then
                humanoid:EquipTool(tool)
                task.wait(0.05)
            end

            -- Fire as fast as possible
            TrainTreadmillEvent:FireServer(true)
        end
        task.wait(0.05)
    end
end)

