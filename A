-- ════════════════════════════════════════════
-- //  Helper: find the base owned by LocalPlayer
-- ════════════════════════════════════════════
local function getPlayerBase()
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return nil end
    for i = 1, 5 do
        local base = plots:FindFirstChild("Base" .. i)
        if base then
            local owner = base:GetAttribute("Owner")
            if owner == lp.UserId then
                return base
            end
        end
    end
    return nil
end

-- ════════════════════════════════════════════
-- //  Helper: teleport root to a part (10 frames)
-- ════════════════════════════════════════════
local function teleportToPart(part)
    local character = lp.Character or lp.CharacterAdded:Wait()
    local root      = character:WaitForChild("HumanoidRootPart")
    local target    = CFrame.new(part.Position + Vector3.new(0, 3, 0))
    for _ = 1, 10 do
        root.CFrame                  = target
        root.AssemblyLinearVelocity  = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        RunService.Heartbeat:Wait()
    end
end

