-- //  Auto Farm Loop
-- ════════════════════════════════════════════
task.spawn(function()
    while true do
        if autoFarmEnabled then
            dashEvent:FireServer("StartCharge")
            dashEvent:FireServer(514953441917896)
            teleportToBestWall()
            dashEvent:FireServer("ClearDash")
        end
        task.wait(10)
    end
end)

-- ════════════════════════════════════════════
-- //  Auto Buy Loop
-- ════════════════════════════════════════════
task.spawn(function()
    while true do
        if autoBuyEnabled and #selectedRarities > 0 then
            for _, rarity in ipairs(selectedRarities) do
                ReplicatedStorage
                    :WaitForChild("Events")
                    :WaitForChild("SendTreadmillEvent")
                    :InvokeServer("Buy", rarity)
                task.wait(0.1)
            end
        end
        task.wait(0.5)
    end
end)

