-- ════════════════════════════════════════════
-- //  Speed Wall Thresholds (based on Stamina)
-- ════════════════════════════════════════════
local speedWallThresholds = {
    { min = 0,               wall = "SpeedWall_1"  },
    { min = 1000,            wall = "SpeedWall_2"  },
    { min = 15000,           wall = "SpeedWall_3"  },
    { min = 225000,          wall = "SpeedWall_4"  },
    { min = 3375000,         wall = "SpeedWall_5"  },
    { min = 50000000,        wall = "SpeedWall_6"  },
    { min = 750000000,       wall = "SpeedWall_7"  },
    { min = 11250000000,     wall = "SpeedWall_8"  },
    { min = 168750000000,    wall = "SpeedWall_9"  },
    { min = 2500000000000,   wall = "SpeedWall_10" },
    { min = 37500000000000,  wall = "SpeedWall_11" },
    { min = 562500000000000, wall = "SpeedWall_12" },
}

local function getBestSpeedWall()
    local stamina = lp:GetAttribute("Stamina") or 0
    local currentIndex = 1
    for i, entry in ipairs(speedWallThresholds) do
        if stamina >= entry.min then
            currentIndex = i
        end
    end
    local nextIndex = math.min(currentIndex + 1, #speedWallThresholds)
    return speedWallThresholds[nextIndex].wall
end

-- ════════════════════════════════════════════
-- //  Teleport
-- ════════════════════════════════════════════
local function teleportToBestWall()
    local character = lp.Character or lp.CharacterAdded:Wait()
    local root      = character:WaitForChild("HumanoidRootPart")
    local humanoid  = character:WaitForChild("Humanoid")
    local wallName  = getBestSpeedWall()

    local speedWalls = Workspace:FindFirstChild("Gameplay")
        and Workspace.Gameplay:FindFirstChild("SpeedWalls")
    local wall = speedWalls and speedWalls:FindFirstChild(wallName)

    if not wall then
        warn("[Teleport] Wall not found:", wallName)
        return
    end

    print("[Teleport] -> " .. wallName)

    local prevWalk = humanoid.WalkSpeed
    local prevJump = humanoid.JumpPower
    humanoid.WalkSpeed = 0
    humanoid.JumpPower = 0

    local target = CFrame.new(wall.Position + Vector3.new(0, 5, 0))

    for _ = 1, 10 do
        root.CFrame                  = target
        root.AssemblyLinearVelocity  = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        RunService.Heartbeat:Wait()
    end

    humanoid.WalkSpeed = prevWalk
    humanoid.JumpPower = prevJump
end

